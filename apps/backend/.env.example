# --- App ---
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql://lift_admin:lift_password@localhost:5432/lift_saas?schema=public

# --- JWT ---
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_TOKEN_COOKIE_NAME=lift_saas_refresh_token

# --- AWS S3 ---
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=lift-saas-uploads

# --- AWS SES ---
AWS_SES_FROM_EMAIL=no-reply@liftsaas.example.com
AWS_SES_REGION=ap-south-1

# --- Logging ---
LOG_LEVEL=debug

# --- Phase 1 Tenant (static, resolved via TenantContext middleware, never hardcoded in business logic) ---
DEFAULT_TENANT_ID=1
DEFAULT_ORGANIZATION_ID=1
